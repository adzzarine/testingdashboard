<script>
function showPage(key){
  document.querySelectorAll('.page').forEach(function(p){p.classList.remove('active')});
  document.querySelectorAll('.nav-item').forEach(function(n){n.classList.remove('active')});
  var el=document.getElementById('page-'+key);
  if(el){el.classList.add('active');window.scrollTo(0,0)}
  event.currentTarget && event.currentTarget.classList.add('active');
}

function switchTab(btn,targetId){
  var bar=btn.closest('.tab-bar');
  bar.querySelectorAll('.tab-btn').forEach(function(b){b.classList.remove('active')});
  btn.classList.add('active');
  var page=btn.closest('.page');
  page.querySelectorAll('.tab-panel').forEach(function(p){p.classList.remove('active')});
  var target=document.getElementById(targetId);
  if(target)target.classList.add('active');
}

// Set active nav on click
document.querySelectorAll('.nav-item[onclick]').forEach(function(item){
  item.addEventListener('click',function(){
    document.querySelectorAll('.nav-item').forEach(function(n){n.classList.remove('active')});
    this.classList.add('active');
  });
});
</script>
