<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Guidebook Third Party Data Management — PeopleVerse</title>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --pv-blue:#1A3A6B;--pv-teal:#68CBC7;--pv-light:#D0edfa;--pv-dark:#000000;--pv-white:#ffffff;
  --pv-teal-mid:#4AADAA;--pv-light-bg:#EFF9FF;--pv-border:#D0edfa;
}
body{font-family:'Montserrat',sans-serif;background:#F4F7FB;color:#222}
.gb-layout{display:flex;min-height:100vh}

/* SIDEBAR */
.gb-sidebar{width:240px;min-width:240px;background:var(--pv-blue);position:fixed;top:0;left:0;height:100vh;overflow-y:auto;z-index:100;display:flex;flex-direction:column}
.sidebar-logo{padding:20px 16px 14px;border-bottom:1px solid rgba(255,255,255,0.1)}
.sidebar-logo-txt{color:#fff;font-size:14px;font-weight:700;letter-spacing:0.5px}
.sidebar-logo-sub{color:var(--pv-teal);font-size:10px;font-weight:500;margin-top:3px}
.sidebar-nav{padding:8px 0;flex:1}
.nav-section{padding:14px 16px 4px;color:rgba(255,255,255,0.35);font-size:9px;font-weight:700;letter-spacing:1.2px;text-transform:uppercase}
.nav-item{display:block;padding:9px 16px;color:rgba(255,255,255,0.72);font-size:11.5px;font-weight:500;cursor:pointer;border-left:3px solid transparent;transition:all .18s;text-decoration:none;line-height:1.4}
.nav-item:hover{background:rgba(255,255,255,0.08);color:#fff;border-left-color:var(--pv-teal)}
.nav-item.active{background:rgba(104,203,199,0.15);color:#fff;border-left-color:var(--pv-teal);font-weight:600}
.sidebar-footer{padding:14px 16px;border-top:1px solid rgba(255,255,255,0.1);color:rgba(255,255,255,0.35);font-size:9px}

/* MAIN */
.gb-main{margin-left:240px;flex:1;min-height:100vh}
.page{display:none;padding:36px 40px;max-width:960px}
.page.active{display:block}

/* COVER */
.cover-banner{background:linear-gradient(135deg,var(--pv-blue) 0%,#0d2a54 60%,#041830 100%);border-radius:16px;padding:52px 48px;position:relative;overflow:hidden;margin-bottom:32px}
.cover-banner::before{content:'';position:absolute;top:-100px;right:-100px;width:500px;height:500px;border-radius:50%;border:1px solid rgba(104,203,199,0.12)}
.cover-banner::after{content:'';position:absolute;top:-50px;right:-50px;width:320px;height:320px;border-radius:50%;border:1px solid rgba(104,203,199,0.18)}
.cover-badge{background:rgba(104,203,199,0.2);border:1px solid var(--pv-teal);color:var(--pv-teal);font-size:10px;font-weight:700;letter-spacing:1.5px;padding:4px 14px;border-radius:20px;margin-bottom:20px;display:inline-block}
.cover-title{color:#fff;font-size:38px;font-weight:700;line-height:1.2;margin-bottom:10px}
.cover-title span{color:var(--pv-teal)}
.cover-sub{color:rgba(255,255,255,0.62);font-size:13.5px;font-weight:400;margin-bottom:32px;max-width:500px;line-height:1.65}
.cover-meta{display:flex;gap:28px;flex-wrap:wrap}
.cover-meta-item{color:rgba(255,255,255,0.45);font-size:11px}
.cover-meta-item strong{color:var(--pv-teal);display:block;font-size:13px;font-weight:600;margin-bottom:2px}
.cover-nav{display:flex;gap:12px;margin-top:28px;flex-wrap:wrap;position:relative;z-index:2}
.btn-primary{background:var(--pv-teal);color:#fff;border:none;padding:11px 22px;border-radius:8px;font-family:'Montserrat',sans-serif;font-size:12px;font-weight:600;cursor:pointer;transition:all .2s}
.btn-primary:hover{background:var(--pv-teal-mid);transform:translateY(-1px)}
.btn-outline{background:transparent;color:#fff;border:1px solid rgba(255,255,255,0.3);padding:11px 22px;border-radius:8px;font-family:'Montserrat',sans-serif;font-size:12px;font-weight:500;cursor:pointer;transition:all .2s}
.btn-outline:hover{border-color:#fff;background:rgba(255,255,255,0.08)}

/* SECTION HEADER */
.section-header{background:var(--pv-blue);padding:26px 40px;margin:-36px -40px 28px -40px;border-radius:0}
.section-badge{background:rgba(104,203,199,0.22);color:var(--pv-teal);font-size:9px;font-weight:700;letter-spacing:1.2px;padding:3px 10px;border-radius:12px;display:inline-block;margin-bottom:8px}
.section-title{color:#fff;font-size:23px;font-weight:700}
.section-desc{color:rgba(255,255,255,0.6);font-size:12px;font-weight:400;margin-top:4px;line-height:1.55}

/* BREADCRUMB */
.breadcrumb{font-size:11px;color:#999;margin-bottom:22px;display:flex;align-items:center;gap:5px}
.breadcrumb span{color:var(--pv-teal);font-weight:600}

/* CARDS */
.card{background:#fff;border:1px solid #e4eef5;border-radius:12px;padding:20px 22px;margin-bottom:16px;box-shadow:0 1px 4px rgba(26,58,107,0.05)}
.card-teal{border-left:3px solid var(--pv-teal);background:var(--pv-light-bg)}
.card-title{font-size:13px;font-weight:700;color:var(--pv-blue);margin-bottom:8px}
.card-body{font-size:12px;color:#444;line-height:1.75}

/* GRID */
.grid-2{display:grid;grid-template-columns:1fr 1fr;gap:16px}
.grid-3{display:grid;grid-template-columns:repeat(3,1fr);gap:14px}

/* FLOW */
.flow-title{font-size:14px;font-weight:700;color:var(--pv-blue);margin:24px 0 14px;display:flex;align-items:center;gap:8px}
.flow-title::before{content:'';width:4px;height:18px;background:var(--pv-teal);border-radius:2px;display:inline-block;flex-shrink:0}
.flow-container{overflow-x:auto;padding-bottom:8px;border:1px solid #e4eef5;border-radius:12px;background:#fff;box-shadow:0 1px 4px rgba(26,58,107,0.04)}
.actors-row{display:flex;gap:0;min-width:600px}
.actor-col{flex:1;min-width:130px}
.actor-head{background:var(--pv-blue);color:#fff;text-align:center;padding:10px 8px;font-size:9.5px;font-weight:700;letter-spacing:0.3px;line-height:1.3}
.actor-head.teal{background:var(--pv-teal)}
.actor-head.light{background:var(--pv-light);color:var(--pv-blue)}
.actor-head.dark{background:#1a1a2e;color:#fff}
.actor-body{padding:12px 10px;border-right:1px dashed #d8eef5;min-height:280px;background:#fafefe}
.actor-body:last-child{border-right:none}
.pbox{border-radius:8px;padding:9px 10px;font-size:10px;font-weight:600;text-align:center;line-height:1.45;margin:5px 0}
.pbox-blue{background:var(--pv-blue);color:#fff}
.pbox-teal{background:var(--pv-teal);color:#fff}
.pbox-light{background:var(--pv-light);color:var(--pv-blue);border:1px solid #b8def0}
.pbox-white{background:#fff;color:var(--pv-blue);border:1.5px solid var(--pv-blue)}
.arr{text-align:center;color:var(--pv-teal);margin:3px 0;font-size:16px;line-height:1}
.step-tag{display:inline-block;background:var(--pv-light);color:var(--pv-blue);font-size:8px;font-weight:700;padding:2px 7px;border-radius:8px;margin-top:4px}
.step-tag.orange{background:#FFE0B2;color:#BF360C}

/* TABLE */
.info-table{width:100%;border-collapse:collapse;font-size:11.5px;margin:14px 0;background:#fff;border-radius:10px;overflow:hidden;box-shadow:0 1px 4px rgba(26,58,107,0.05)}
.info-table th{background:var(--pv-blue);color:#fff;padding:10px 14px;text-align:left;font-weight:600;font-size:10.5px}
.info-table td{padding:9px 14px;border-bottom:1px solid #eef3f8;color:#444;vertical-align:top;line-height:1.55}
.info-table tr:last-child td{border-bottom:none}
.info-table tr:hover td{background:#f5fbfe}
.badge{display:inline-block;padding:2px 10px;border-radius:10px;font-size:9.5px;font-weight:700}
.badge-teal{background:rgba(104,203,199,0.18);color:#0d8f8a}
.badge-blue{background:rgba(26,58,107,0.1);color:var(--pv-blue)}
.badge-orange{background:#FFF3E0;color:#BF360C}

/* TABS */
.tab-bar{display:flex;gap:0;border-bottom:2px solid #e4eef5;margin-bottom:20px;overflow-x:auto}
.tab-btn{padding:10px 18px;font-family:'Montserrat',sans-serif;font-size:11px;font-weight:600;color:#999;background:none;border:none;border-bottom:2px solid transparent;cursor:pointer;white-space:nowrap;transition:all .18s;margin-bottom:-2px}
.tab-btn:hover{color:var(--pv-blue)}
.tab-btn.active{color:var(--pv-blue);border-bottom-color:var(--pv-teal)}
.tab-panel{display:none}
.tab-panel.active{display:block}

/* HIGHLIGHT BOX */
.highlight-box{border-radius:10px;padding:16px 20px;margin:14px 0;border:1px solid var(--pv-teal);background:var(--pv-light-bg)}
.highlight-box .hb-title{font-size:12.5px;font-weight:700;color:var(--pv-blue);margin-bottom:5px}
.highlight-box .hb-body{font-size:11.5px;color:#444;line-height:1.7}
.warn-box{border-color:#F5C842;background:#FFFDF0}
.danger-box{border-color:#FFCDD2;background:#FFF5F5}

/* DEADLINE PILLS */
.deadline-row{display:flex;gap:8px;margin-top:16px;flex-wrap:wrap}
.deadline-pill{color:#fff;border-radius:8px;padding:6px 16px;font-size:10.5px;font-weight:700}
.dp-blue{background:var(--pv-blue)}
.dp-teal{background:var(--pv-teal)}
.dp-dark{background:#1a1a2e}

/* PILL ROW */
.pill-row{display:flex;flex-wrap:wrap;gap:8px;margin:12px 0}
.pill{background:var(--pv-light);color:var(--pv-blue);font-size:10px;font-weight:600;padding:5px 13px;border-radius:20px}
.pill.teal{background:var(--pv-teal);color:#fff}

/* RESPONSIVE */
@media(max-width:760px){
  .gb-sidebar{display:none}
  .gb-main{margin-left:0}
  .page{padding:20px 18px}
  .section-header{margin:-20px -18px 20px -18px;padding:20px 18px}
  .grid-2,.grid-3{grid-template-columns:1fr}
  .cover-title{font-size:26px}
  .cover-banner{padding:32px 24px}
}
</style>
</head>
<body>
<div class="gb-layout">

<!-- SIDEBAR -->
<nav class="gb-sidebar">
  <div class="sidebar-logo">
    <div class="sidebar-logo-txt">🔵 PeopleVerse</div>
    <div class="sidebar-logo-sub">Third Party Data Guidebook</div>
  </div>
  <div class="sidebar-nav">
    <div class="nav-section">Umum</div>
    <a class="nav-item active" onclick="showPage('cover')">🏠 Beranda</a>
    <a class="nav-item" onclick="showPage('overview')">📋 Executive Summary</a>

    <div class="nav-section">Onboarding</div>
    <a class="nav-item" onclick="showPage('preonboard')">👤 Pre-onboarding</a>

    <div class="nav-section">Career Transition</div>
    <a class="nav-item" onclick="showPage('contract')">📄 Perpanjangan Kontrak</a>
    <a class="nav-item" onclick="showPage('rotation')">🔄 Rotasi Personel</a>

    <div class="nav-section">Offboarding</div>
    <a class="nav-item" onclick="showPage('resign')">🚪 Resign</a>
    <a class="nav-item" onclick="showPage('eoc')">📅 End of Contract</a>
    <a class="nav-item" onclick="showPage('deceased')">🕊️ Meninggal Dunia</a>
  </div>
  <div class="sidebar-footer">Update: April 2026 · PeopleVerse v7.0</div>
</nav>

<!-- MAIN CONTENT -->
<main class="gb-main">

<!-- ===== COVER ===== -->
<div class="page active" id="page-cover">
  <div class="cover-banner">
    <div class="cover-badge">OFFICIAL GUIDEBOOK · 2026</div>
    <div class="cover-title">Third Party<br><span>Data Management</span></div>
    <div class="cover-sub">Panduan resmi pengelolaan data personel Third Party di sistem PeopleVerse — untuk PIC 3rd Party dan HRBP DC.</div>
    <div class="cover-meta">
      <div class="cover-meta-item"><strong>Target User</strong>PIC 3rd Party · HRBP DC</div>
      <div class="cover-meta-item"><strong>Sistem</strong>PeopleVerse (Sunfish 7.0)</div>
      <div class="cover-meta-item"><strong>Update</strong>April 2026</div>
    </div>
    <div class="cover-nav">
      <button class="btn-primary" onclick="showPage('overview')">Mulai Baca →</button>
      <button class="btn-outline" onclick="showPage('preonboard')">Lihat Flow Onboarding</button>
    </div>
  </div>
  <div class="grid-3" style="margin-top:0">
    <div class="card card-teal" style="cursor:pointer" onclick="showPage('preonboard')">
      <div style="font-size:26px;margin-bottom:8px">👤</div>
      <div class="card-title">Onboarding</div>
      <div class="card-body">Pre-onboarding & proses tambah personel baru ke sistem PeopleVerse</div>
    </div>
    <div class="card card-teal" style="cursor:pointer" onclick="showPage('contract')">
      <div style="font-size:26px;margin-bottom:8px">📄</div>
      <div class="card-title">Career Transition</div>
      <div class="card-body">Perpanjangan kontrak, rotasi, perubahan posisi & working location</div>
    </div>
    <div class="card card-teal" style="cursor:pointer" onclick="showPage('resign')">
      <div style="font-size:26px;margin-bottom:8px">🚪</div>
      <div class="card-title">Offboarding</div>
      <div class="card-body">Proses resign, end of contract, meninggal dunia, dan pensiun</div>
    </div>
  </div>
</div>

<!-- ===== OVERVIEW ===== -->
<div class="page" id="page-overview">
  <div class="section-header">
    <div class="section-badge">EXECUTIVE SUMMARY</div>
    <div class="section-title">Mengapa Guidebook ini Penting?</div>
    <div class="section-desc">Panduan adopsi PeopleVerse untuk seluruh proses HR Third Party</div>
  </div>
  <div class="breadcrumb">Beranda › <span>Executive Summary</span></div>
  <div class="highlight-box">
    <div class="hb-title">🎯 Tujuan Guidebook</div>
    <div class="hb-body">Guidebook ini disusun sebagai panduan resmi bagi seluruh pengguna sistem HRIS (PeopleVerse) dalam memahami alur, fitur, serta tata cara penggunaan sistem sesuai proses yang telah ditentukan — khususnya untuk pengelolaan data personel Third Party.</div>
  </div>
  <div class="grid-2" style="margin-top:16px">
    <div class="card">
      <div class="card-title">📌 Objectives</div>
      <div class="card-body">
        <div style="display:flex;gap:10px;margin-bottom:10px;align-items:flex-start"><span style="color:var(--pv-teal);font-weight:700;flex-shrink:0">01.</span><span>Membantu proses adopsi HRIS baru (PeopleVerse) di Paragon</span></div>
        <div style="display:flex;gap:10px;align-items:flex-start"><span style="color:var(--pv-teal);font-weight:700;flex-shrink:0">02.</span><span>Menjadi referensi utama penggunaan HRIS bagi PIC 3rd Party, HRBP DC, dan HRS HO</span></div>
      </div>
    </div>
    <div class="card">
      <div class="card-title">👥 Siapa Penggunanya?</div>
      <div class="card-body">
        <div class="pill-row">
          <span class="pill teal">PIC 3rd Party</span>
          <span class="pill teal">HRBP DC (Area)</span>
          <span class="pill">HRS HO & Plant</span>
          <span class="pill">HRS HO Admin</span>
          <span class="pill">Superior / Atasan</span>
          <span class="pill">Koordinator Area</span>
        </div>
      </div>
    </div>
  </div>
  <div class="flow-title">Ruang Lingkup Proses</div>
  <table class="info-table">
    <thead><tr><th>Kategori</th><th>Proses</th><th>PIC Utama</th></tr></thead>
    <tbody>
      <tr><td><span class="badge badge-blue">Onboarding</span></td><td>Pre-onboarding & Tambah Personel Baru</td><td>PIC 3rd Party → HRBP DC</td></tr>
      <tr><td rowspan="2"><span class="badge badge-teal">Career Transition</span></td><td>Perpanjangan Kontrak</td><td>PIC 3rd Party → HRBP DC → HRS HO</td></tr>
      <tr><td>Rotasi Personel</td><td>Superior → HRBP DC Area</td></tr>
      <tr><td rowspan="4"><span class="badge badge-orange">Offboarding</span></td><td>Resign</td><td>Personel → PIC 3rd Party → HRS</td></tr>
      <tr><td>End of Contract</td><td>Kontrak 1 → HRBP DC → PIC 3rd Party</td></tr>
      <tr><td>Meninggal Dunia</td><td>PIC 3rd Party → HRS</td></tr>
      <tr><td>Pensiun</td><td>HRS HO</td></tr>
    </tbody>
  </table>
  <div class="highlight-box warn-box" style="margin-top:20px">
    <div class="hb-title">⚠️ Penting Diperhatikan</div>
    <div class="hb-body">Setiap proses memiliki <strong>deadline input data</strong> di sistem PeopleVerse. Keterlambatan input akan berdampak pada proses payroll dan employment status personel. Pastikan selalu mengikuti timeline yang tertera di setiap bagian.</div>
  </div>
</div>

<!-- ===== PRE-ONBOARDING ===== -->
<div class="page" id="page-preonboard">
  <div class="section-header">
    <div class="section-badge">ONBOARDING</div>
    <div class="section-title">Pre-onboarding & Onboarding</div>
    <div class="section-desc">Proses penambahan personel Third Party baru ke dalam sistem PeopleVerse</div>
  </div>
  <div class="breadcrumb">Onboarding › <span>Pre-onboarding & Onboarding</span></div>
  <div class="highlight-box">
    <div class="hb-title">📌 Apa itu Pre-onboarding?</div>
    <div class="hb-body">Pre-onboarding adalah proses persiapan sebelum personel baru resmi bergabung. PIC 3rd Party bertanggung jawab melakukan request penambahan personel baru dan melengkapi data awal, yang kemudian disetujui oleh HRBP DC dan diinput ke sistem PeopleVerse oleh HRS HO.</div>
  </div>
  <div class="flow-title">Alur Proses (Flow)</div>
  <div class="tab-bar">
    <button class="tab-btn active" onclick="switchTab(this,'ob1')">HO &amp; Plant</button>
    <button class="tab-btn" onclick="switchTab(this,'ob2')">Area (DC)</button>
  </div>
  <div id="ob1" class="tab-panel active">
    <div class="flow-container">
      <div class="actors-row">
        <div class="actor-col">
          <div class="actor-head">PIC 3rd Party</div>
          <div class="actor-body">
            <div class="pbox pbox-light">Melakukan request penambahan personel baru</div>
            <div class="arr">↓</div>
            <div class="pbox pbox-light">Menginput kelengkapan data personel baru &amp; kirim ke approver</div>
            <div style="height:48px"></div>
            <div class="pbox pbox-light">Menginput data personel yang harus dilengkapi melalui <em>Employee Information</em></div>
            <div><span class="step-tag">H-5</span></div>
          </div>
        </div>
        <div class="actor-col">
          <div class="actor-head teal">HRBP DC / HRS HO &amp; Plant</div>
          <div class="actor-body">
            <div style="height:56px"></div>
            <div class="pbox pbox-teal">Menyetujui request data personel baru</div>
            <div><span class="step-tag">H-6</span></div>
            <div class="arr">↓</div>
            <div class="pbox pbox-white">Menginput data yang harus dilengkapi PIC &amp; HRBP DC via Employee Information</div>
            <div><span class="step-tag">H-5</span></div>
            <div class="arr">↓</div>
            <div class="pbox pbox-teal">Mengajukan pembuatan akun corporate Paragon via email sesuai kebutuhan Superior</div>
            <div><span class="step-tag">H-5</span></div>
            <div class="arr">↓</div>
            <div class="pbox pbox-white">Menginput akun corporate Paragon personel baru</div>
            <div><span class="step-tag">H-3</span></div>
          </div>
        </div>
        <div class="actor-col">
          <div class="actor-head light">HRS HO</div>
          <div class="actor-body">
            <div style="height:120px"></div>
            <div class="pbox pbox-blue">Mereview dan menyetujui request pembuatan akun corporate Paragon</div>
            <div><span class="step-tag">H-4</span></div>
          </div>
        </div>
      </div>
    </div>
    <div class="deadline-row">
      <span class="deadline-pill dp-dark">PIC 3rd Party: H-7</span>
      <span class="deadline-pill dp-teal">HRBP DC: H-3</span>
      <span class="deadline-pill dp-blue">HRS HO: H-4</span>
    </div>
  </div>
  <div id="ob2" class="tab-panel">
    <div class="highlight-box" style="background:#E8F4FE;border-color:#90CAF9">
      <div class="hb-title">ℹ️ Catatan untuk Area (DC)</div>
      <div class="hb-body">Untuk Area/DC, HRBP DC Area berperan lebih aktif dalam melengkapi data dan berkoordinasi langsung dengan PIC 3rd Party.</div>
    </div>
    <div class="flow-container">
      <div class="actors-row">
        <div class="actor-col">
          <div class="actor-head">PIC 3rd Party</div>
          <div class="actor-body">
            <div class="pbox pbox-light">Request penambahan personel baru</div>
            <div class="arr">↓</div>
            <div class="pbox pbox-light">Input kelengkapan data &amp; kirim ke HRBP DC Area</div>
            <div><span class="step-tag">H-7</span></div>
          </div>
        </div>
        <div class="actor-col">
          <div class="actor-head teal">HRBP DC (Area)</div>
          <div class="actor-body">
            <div class="pbox pbox-teal">Verifikasi &amp; approve request dari PIC</div>
            <div class="arr">↓</div>
            <div class="pbox pbox-white">Melengkapi data personel di Employee Information</div>
            <div class="arr">↓</div>
            <div class="pbox pbox-teal">Koordinasi pembuatan akun corporate</div>
            <div><span class="step-tag">H-3</span></div>
          </div>
        </div>
        <div class="actor-col">
          <div class="actor-head light">HRS HO</div>
          <div class="actor-body">
            <div class="pbox pbox-blue">Review &amp; approve pembuatan akun corporate Paragon</div>
            <div><span class="step-tag">H-4</span></div>
          </div>
        </div>
      </div>
    </div>
